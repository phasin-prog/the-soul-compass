{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "safe-repo-workflow": "allow",
      "pro-uiux-sitemap-overhaul": "allow",
      "information-architecture-audit": "allow",
      "visual-design-system-audit": "allow",
      "accessibility-performance-qa": "allow",
      "fullstack-regression-guard": "allow",
      "studio-ui-system": "allow",
      "nextjs-tailwind-qa": "allow",
      "experimental-*": "ask",
      "external-*": "ask",
      "*": "ask"
    },
    "edit": "ask",
    "bash": "ask"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "plugin": [
    ["opencode-tool-search@latest", {
      "alwaysLoad": ["read", "write", "edit", "bash", "glob", "grep"]
    }]
  ]
}
